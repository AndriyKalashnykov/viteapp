    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "terser": "5.47.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.16",
    "vitest": "4.1.5",
    "web-vitals": "5.2.0"
