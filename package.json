{
  "name": "viteapp",
  "private": true,
  "version": "v0.0.3",
  "type": "module",
  "author": "AndriyKalashnykov(AndriyKalashnykov@gmail.com)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prettier": "prettier --ignore-path .gitignore --write 'src/**/*.{ts,tsx,js,jsx}'",
    "prettier:diff": "prettier -l 'src/**/*.{ts,tsx,js,jsx}'",
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": "prettier --ignore-path .gitignore --write 'src/**/*.{ts,tsx,js,jsx}'"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "dependencies": {
    "env-var": "^7.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "pretty-quick": "4.2.2",
    "simple-git-hooks": "2.13.1",
    "terser": "5.46.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "8.0.1",
    "web-vitals": "5.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "pnpm": {
    "overrides": {
      "svgo": "npm:@kingyue/svgo@^2.9.0"
    },
    "ignoredBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
